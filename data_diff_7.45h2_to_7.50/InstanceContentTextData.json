"43920":{"Text":["_rsv_43920_-1_1_0_0_S13095D61_E13095D61","Snakes alive! It's the birth of a new Lindwurm!"]},"43921":{"Text":["_rsv_43921_-1_1_0_0_S13095D61_E13095D61","Alas, the battle isn't over yet... But don't despair, Champion!"]},"43922":{"Text":["_rsv_43922_-1_1_0_0_S13095D61_E13095D61","The Lindwurm is creating more of itself!"]},"43923":{"Text":["_rsv_43923_-1_1_0_0_S13095D61_E13095D61","The Lindwurm continues to multiply! We've gone well beyond mortal limits now! "]},"43924":{"Text":["_rsv_43924_-1_1_0_0_S13095D61_E13095D61","Some curious props have appeared! What could they possibly be?"]},"43925":{"Text":["_rsv_43925_-1_1_0_0_S13095D61_E13095D61","Egads, they've taken on the champion's form! This bodes ill!"]},"43926":{"Text":["_rsv_43926_-1_1_0_0_S13095D61_E13095D61","I've got a serious case of deja vu here..."]},"43927":{"Text":["_rsv_43927_-1_1_0_0_S13095D61_E13095D61","What destructiveness! The ring has been rent in two!"]},"43928":{"Text":["_rsv_43928_-1_1_0_0_S13095D61_E13095D61","The mutation is corrupting the champion! Let's hope they keep it together!"]},"43929":{"Text":["_rsv_43929_-1_1_0_0_S13095D61_E13095D61","Something's coming... Stay on your toes!"]},"43930":{"Text":["_rsv_43930_-1_1_0_0_S13095D61_E13095D61","What is this place? Did the Lindwurm warp the very fabric of space and time!?"]},"43931":{"Text":["_rsv_43931_-1_1_0_0_S13095D61_E13095D61","Is this another dimension? I must confess, I'm utterly bewildered..."]},"43932":{"Text":["_rsv_43932_-1_1_0_0_S13095D61_E13095D61","A relentless assault! The champion is hard-pressed!"]},"43933":{"Text":["_rsv_43933_-1_1_0_0_S13095D61_E13095D61","The battle has reached a fever pitch! But the champion still stands!"]},"43934":{"Text":["_rsv_43934_-1_1_0_0_S13095D61_E13095D61","There's so many of them... Stay strong, I beg you!"]},"43935":{"Text":["_rsv_43935_-1_1_0_0_S13095D61_E13095D61","I'm not sure I understand what's going on anymore, folks."]},"43936":{"Text":["_rsv_43936_-1_1_0_0_S13095D61_E13095D61","We appear to have completely left the realm of logic behind."]},"43937":{"Text":["_rsv_43937_-1_1_0_0_S13095D61_E13095D61","Something that defies all comprehension is unfolding before our very eyes!"]}}}